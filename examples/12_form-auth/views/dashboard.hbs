<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <style>
        body { font-family: sans-serif; max-width: 640px; margin: 80px auto; padding: 0 20px; }
        h1 { color: #4f46e5; }
        .card { padding: 20px 24px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; }
        .label { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
        .value { font-size: 1rem; color: #111827; margin-top: 2px; }
        .field + .field { margin-top: 16px; }
        a.logout { display: inline-block; margin-top: 24px; padding: 8px 16px; background: #ef4444; color: #fff; border-radius: 6px; text-decoration: none; font-size: 0.875rem; }
        a.logout:hover { background: #dc2626; }
    </style>
</head>

<body>
    <h1>Welcome, {{name}}!</h1>
    <div class="card">
        <div class="field">
            <div class="label">Email</div>
            <div class="value">{{email}}</div>
        </div>
    </div>
    <a class="logout" href="/logout">Logout</a>
</body>

</html>
